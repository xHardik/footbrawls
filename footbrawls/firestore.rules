rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — open for now (UUID-based, no Firebase Auth)
    match /users/{userId} {
      allow read, write: if true;
    }

    // Raid Queue
    match /raidQueue/{userId} {
      allow read: if true;
      allow create, update: if request.resource.data.userId == userId
        && request.resource.data.status in ['waiting', 'matched'];
      allow delete: if true;
    }

    // Game Sessions (Must be open for client-side matching & play)
    match /gameSessions/{docId} {
      allow read, write: if true;
    }

    // Guilds — read freely, write allowed for castleHP increments from client
    match /guilds/{guildId} {
      allow read: if true;
      allow write: if true; // xpEngine runs client-side so needs write access
    }

    // Fixtures — read only
    match /fixtures/{fixtureId} {
      allow read: if true;
      allow write: if false;
    }

    // Chat
    match /chat/{messageId} {
      allow read, write: if true;
    }

    // Activity feed
    match /activity/{activityId} {
      allow read, write: if true;
    }

    // Predictions
    match /predictions/{predId} {
      allow read, write: if true;
    }
  }
}
