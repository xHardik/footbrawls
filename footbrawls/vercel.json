{
  "crons": [
    {
      "path": "/api/cron/midnight-reset",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/match-poller",
      "schedule": "*/2 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:"
        }
      ]
    }
  ]
}